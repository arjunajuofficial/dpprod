# ─────────────────────────────────────────────────────────────────────────────
# Station Monitor — production environment
#
#   cp .env.example .env   &&   edit the values below
#
# NEVER commit .env to version control. docker-compose reads this file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Security (REQUIRED) ──────────────────────────────────────────────────────
# JWT signing key. Production refuses to start with a weak/short key (< 32 chars).
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=rWnBANRh2MM8kVqiTmBwQczslHygnyCayjIhtX8iOxHGQCFZQx7cgwjAu0UKrf3e

# First-run admin account (only seeded when the database is empty).
# Change the password immediately after first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Shared secret between the backend and the station agents (X-Agent-Key header).
# Set the SAME value on every agent (agent.py --api-key <value>).
# Leave blank only for trusted, isolated networks.
AGENT_API_KEY=qwerty

# ── Frontend → backend wiring (REQUIRED) ─────────────────────────────────────
# The externally reachable backend URL, baked into the frontend bundle at build.
# Use your server's hostname/IP, e.g. http://monitor.example.com:8000
VITE_API_BASE=
VITE_WS_URL=

# ── Behaviour ────────────────────────────────────────────────────────────────
# true = generate fake server data (demo only). Keep false in production.
MOCK_MONITORING=false

# ── Database ─────────────────────────────────────────────────────────────────
# Default: SQLite on the docker named volume (correct for a single instance
# monitoring up to ~100 servers). Leave unset to use the default.
# DATABASE_URL=sqlite+aiosqlite:////data/station_monitor.db
#
# To switch to PostgreSQL (see docker-compose.yml), uncomment and set:
# POSTGRES_PASSWORD=
# DATABASE_URL=postgresql+asyncpg://monitor:${POSTGRES_PASSWORD}@db:5432/station_monitor
