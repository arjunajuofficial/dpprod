# ── Station Monitor backend configuration ───────────────────────────────────
# Copy to .env and fill in real values. NEVER commit .env to git.

# development | production  (production refuses to start with a weak SECRET_KEY)
APP_ENV=development

# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# First-run admin account (only used when seeding an empty database)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-immediately

# Shared secret between backend and station agents (X-Agent-Key header).
# Set the SAME value on every agent:  python agent.py --api-key <value>
AGENT_API_KEY=

# Login brute-force protection
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300

# Monitoring
MOCK_MONITORING=false
PING_INTERVAL=15
METRICS_INTERVAL=60
OFFLINE_THRESHOLD=3
ONLINE_THRESHOLD=2
EVENTS_INTERVAL=120
SERVICES_INTERVAL=15

# Data retention sweep interval (seconds); retention windows are set in the UI
RETENTION_INTERVAL=3600

# Database (default: SQLite file next to the backend)
# DATABASE_URL=sqlite+aiosqlite:///./station_monitor.db
